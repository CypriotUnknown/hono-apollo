{
  "name": "@cypriotunknown/apollo-hono",
  "version": "0.1.4",
  "description": "Apollo Server integration for Hono (Bun runtime)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --format esm --external @apollo/server --external graphql --external graphql-ws --external hono && tsc --project tsconfig.build.json",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "@apollo/server": "^5.0.0",
    "graphql": "^16.0.0",
    "graphql-ws": "^6.0.0",
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@apollo/server-integration-testsuite": "^5.4.0",
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "keywords": [
    "apollo",
    "apollo-server",
    "graphql",
    "hono",
    "bun",
    "websocket",
    "subscriptions"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CypriotUnknown/hono-apollo.git"
  }
}
